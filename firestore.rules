rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: any authenticated user can read (needed for group member queries)
    // Only owner or admin can write; only admin can delete
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (
        request.auth.uid == userId ||
        request.auth.token.email == 'admin@admin.es'
      );
      allow delete: if request.auth != null &&
        request.auth.token.email == 'admin@admin.es';
    }

    // Groups and their matches: any authenticated user can read/write
    match /groups/{groupCode} {
      allow read, write: if request.auth != null;

      match /matches/{matchId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
